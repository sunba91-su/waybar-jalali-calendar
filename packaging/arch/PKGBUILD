# Maintainer: Your Name <your-email@example.com>
# Contributor: sunba91-su

pkgname=waybar-jalali-calendar
pkgver=1.0.0
pkgrel=1
pkgdesc="Jalali (Persian/Solar Hijri) calendar module for Waybar with holiday detection, Nowruz countdown, and monthly calendar grid"
arch=('any')
url="https://github.com/sunba91-su/waybar-jalali-calendar"
license=('GPL3')
depends=('python' 'python-jdatetime' 'python-hijridate')
makedepends=('python-build' 'python-installer' 'python-wheel')
source=("$pkgname-$pkgver.tar.gz::$url/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "$srcdir/$pkgname-$pkgver"
    python -m build --wheel --no-sdist
}

package() {
    cd "$srcdir/$pkgname-$pkgver"
    python -m installer --destdir="$pkgdir" dist/*.whl
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
